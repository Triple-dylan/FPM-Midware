# Copy to `.env` for local use. Scripts load these via dotenv — do not commit `.env`.
#
# PostgreSQL (required for db:apply, webhooks, admin API)
# Local Docker: docker compose up -d  →  postgres://fpm:fpm@localhost:5432/fpm_datatool
# Local Homebrew (no Docker): brew install postgresql@16 && brew services start postgresql@16
#   then: npm run db:local:bootstrap   (creates fpm + fpm_datatool if missing)
# Optional superuser URL for bootstrap only (defaults try $USER then postgres):
# POSTGRES_ADMIN_URL=postgresql://postgres@127.0.0.1:5432/postgres
DATABASE_URL=postgres://fpm:fpm@localhost:5432/fpm_datatool

# HTTP server (sync engine / webhook receiver)
PORT=3000

# Max bytes read for webhook POST bodies (default 524288)
# WEBHOOK_MAX_BODY_BYTES=524288

# Optional: protect GET/PUT /api/automations (paste same value in the admin UI)
# SYNC_ADMIN_TOKEN=your-long-random-secret

# GHL Private Integration Token or OAuth access token (outbound + refresh scripts)
# GHL_ACCESS_TOKEN=

# Aryeo API token (Bearer) — REST reads, pilot, GHL sync from DB; webhooks do not require this
ARYEO_API_KEY=

# Sub-account location id (custom field cache, ghl:refresh-fields). Pilot sync uses **5301 Alpha only** (fixed in script).
# GHL_LOCATION_ID=EkuOnGu2b5wBIzLX6FZ9

# Staging / sandbox: use a separate GHL location + token to test writes without touching prod data.
# Same app; swap these two vars only.

# Deep link template for Aryeo customer profile; {{id}} = customer UUID from order payload
# ARYEO_CUSTOMER_PROFILE_URL=https://app.aryeo.com/customers/{{id}}

# Optional: Aryeo REST base when you add read clients (default https://api.aryeo.com/v1)
# ARYEO_API_BASE_URL=https://api.aryeo.com/v1

# Optional: default GHL user id for `npm run bootstrap:aryeo-cohort` assigned_to when CSV omits it
# GHL_BOOTSTRAP_ASSIGNED_TO=

# Pilot sync allowlist (default: ./config/pilot-cohort.allowlist.json). Must have "exclusive": true.
# PILOT_ALLOWLIST_PATH=

# Pilot CSV / dry-run only: set to 1 to GET every customer id (very slow). Default: skip fetches unless list+order text matches allowlist.
# PILOT_CSV_FULL_SCAN=
