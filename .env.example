# PostgreSQL (required for db:apply, webhooks, admin API)
# Local Docker: docker compose up -d  →  postgres://fpm:fpm@localhost:5432/fpm_datatool
DATABASE_URL=postgres://fpm:fpm@localhost:5432/fpm_datatool

# HTTP server (sync engine / webhook receiver)
PORT=3000

# Max bytes read for webhook POST bodies (default 524288)
# WEBHOOK_MAX_BODY_BYTES=524288

# Optional: protect GET/PUT /api/automations (paste same value in the admin UI)
# SYNC_ADMIN_TOKEN=your-long-random-secret

# GHL API token for outbound contact updates (Aryeo → GHL when toggles allow)
# GHL_ACCESS_TOKEN=

# Sub-account location id (custom field UUID resolution + outbound custom fields)
# GHL_LOCATION_ID=

# Deep link template for Aryeo customer profile; {{id}} = customer UUID from order payload
# ARYEO_CUSTOMER_PROFILE_URL=https://app.aryeo.com/customers/{{id}}

# Optional: Aryeo REST base when you add read clients (default https://api.aryeo.com/v1)
# ARYEO_API_BASE_URL=https://api.aryeo.com/v1
